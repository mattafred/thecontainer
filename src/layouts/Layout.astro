---
interface Props {
	title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="fr" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="The Container Eat & Drink - Mahares" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
	</head>
	<body class="bg-neutral-900 text-white antialiased overflow-x-hidden">
		<slot />
	</body>
</html>